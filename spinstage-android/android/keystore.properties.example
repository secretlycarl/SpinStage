# Copy to keystore.properties (gitignored) for release APK signing.
# Create a keystore once:
#   keytool -genkey -v -keystore spinstage-release.keystore -alias spinstage \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is relative to this android/ directory.

storeFile=spinstage-release.keystore
storePassword=your-store-password
keyAlias=spinstage
keyPassword=your-key-password
